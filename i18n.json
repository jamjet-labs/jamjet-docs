{
  "version": 0,
  "locale": {
    "source": "en",
    "targets": ["ja", "zh", "ko", "es", "de"]
  },
  "buckets": {
    "markdown": {
      "include": [
        "content/docs/[locale]/cloud/*.mdx",
        "content/docs/[locale]/cloud/dashboard/*.mdx",
        "content/docs/[locale]/cloud/get-started/*.mdx",
        "content/docs/[locale]/cloud/governance/*.mdx",
        "content/docs/[locale]/cloud/telemetry/*.mdx",
        "content/docs/[locale]/integrations/*.mdx",
        "content/docs/[locale]/open-source/*.mdx",
        "content/docs/[locale]/open-source/*.md",
        "content/docs/[locale]/open-source/protocols/*.mdx",
        "content/docs/[locale]/open-source/research/*.mdx",
        "content/docs/[locale]/reference/*.mdx",
        "content/docs/[locale]/reference/migrate/*.mdx"
      ]
    }
  },
  "$schema": "https://lingo.dev/schema/i18n.json"
}
